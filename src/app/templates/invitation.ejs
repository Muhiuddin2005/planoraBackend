<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Event Invitation - Planora</title>
</head>
<body style="margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #0f172a;">
    <!-- Full-width dark background wrapper -->
    <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #0f172a 100%); min-height: 100vh;">
        <tr>
            <td align="center" style="padding: 40px 16px;">

                <!-- Main Card Container -->
                <table role="presentation" cellpadding="0" cellspacing="0" width="520" style="max-width: 520px; width: 100%; border-radius: 20px; overflow: hidden; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5), 0 0 40px rgba(99, 102, 241, 0.15);">
                    
                    <!-- Top Gradient Accent Bar -->
                    <tr>
                        <td style="height: 5px; background: linear-gradient(90deg, #6366f1, #a855f7, #ec4899);"></td>
                    </tr>

                    <!-- Card Body -->
                    <tr>
                        <td style="background-color: #1e293b; padding: 40px 36px 36px;">
                            
                            <!-- Logo/Brand -->
                            <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
                                <tr>
                                    <td align="center" style="padding-bottom: 28px;">
                                        <table role="presentation" cellpadding="0" cellspacing="0">
                                            <tr>
                                                <td style="background: linear-gradient(135deg, #6366f1, #8b5cf6); border-radius: 12px; padding: 10px 14px;">
                                                    <img src="https://img.icons8.com/fluency/32/calendar--v1.png" alt="Planora" width="28" height="28" style="display: block;" />
                                                </td>
                                                <td style="padding-left: 12px;">
                                                    <span style="font-size: 22px; font-weight: 800; color: #ffffff; letter-spacing: -0.5px;">Planora<span style="color: #6366f1;">.</span></span>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>

                            <!-- Divider -->
                            <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
                                <tr>
                                    <td style="height: 1px; background: linear-gradient(90deg, transparent, #334155, transparent);"></td>
                                </tr>
                            </table>

                            <!-- Party Icon -->
                            <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
                                <tr>
                                    <td align="center" style="padding: 32px 0 16px;">
                                        <div style="width: 56px; height: 56px; border-radius: 50%; background: rgba(168, 85, 247, 0.1); border: 1px solid rgba(168, 85, 247, 0.25); display: inline-flex; align-items: center; justify-content: center; box-shadow: 0 0 20px rgba(168, 85, 247, 0.15);">
                                            <img src="https://img.icons8.com/fluency/36/confetti.png" alt="Invitation" width="30" height="30" style="display: block;" />
                                        </div>
                                    </td>
                                </tr>
                            </table>

                            <!-- Heading -->
                            <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
                                <tr>
                                    <td align="center" style="padding-bottom: 8px;">
                                        <h1 style="margin: 0; font-size: 24px; font-weight: 800; color: #ffffff; letter-spacing: -0.3px;">You're Invited! 🎉</h1>
                                    </td>
                                </tr>
                                <tr>
                                    <td align="center" style="padding-bottom: 6px;">
                                        <p style="margin: 0; font-size: 14px; color: #94a3b8; line-height: 1.5;">Hello <strong style="color: #c7d2fe;"><%= inviteeName %></strong>,</p>
                                    </td>
                                </tr>
                                <tr>
                                    <td align="center" style="padding-bottom: 28px;">
                                        <p style="margin: 0; font-size: 13px; color: #64748b; line-height: 1.6; max-width: 380px;">
                                            <strong style="color: #a5b4fc;"><%= inviterName %></strong> has invited you to attend an exclusive event on Planora!
                                        </p>
                                    </td>
                                </tr>
                            </table>

                            <!-- Event Details Card -->
                            <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
                                <tr>
                                    <td style="padding-bottom: 28px;">
                                        <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="border-radius: 16px; overflow: hidden; border: 1px solid rgba(99, 102, 241, 0.2); box-shadow: 0 0 20px rgba(99, 102, 241, 0.06);">
                                            <!-- Event Title Header -->
                                            <tr>
                                                <td style="background: linear-gradient(135deg, rgba(30, 27, 75, 0.9), rgba(49, 46, 129, 0.6)); padding: 18px 24px; border-bottom: 1px solid rgba(99, 102, 241, 0.15);">
                                                    <p style="margin: 0; font-size: 11px; color: #818cf8; text-transform: uppercase; letter-spacing: 1.5px; font-weight: 700;">Event</p>
                                                    <h2 style="margin: 6px 0 0; font-size: 20px; font-weight: 800; color: #e0e7ff;"><%= eventName %></h2>
                                                </td>
                                            </tr>
                                            <!-- Event Details -->
                                            <tr>
                                                <td style="background-color: rgba(15, 23, 42, 0.5); padding: 20px 24px;">
                                                    <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
                                                        <tr>
                                                            <td style="padding-bottom: 12px;">
                                                                <p style="margin: 0; font-size: 11px; color: #64748b; text-transform: uppercase; letter-spacing: 1px; font-weight: 600;">📅 Date</p>
                                                                <p style="margin: 4px 0 0; font-size: 14px; color: #e2e8f0; font-weight: 600;"><%= eventDate %></p>
                                                            </td>
                                                        </tr>
                                                        <tr>
                                                            <td style="padding-bottom: 12px;">
                                                                <p style="margin: 0; font-size: 11px; color: #64748b; text-transform: uppercase; letter-spacing: 1px; font-weight: 600;">🕐 Time</p>
                                                                <p style="margin: 4px 0 0; font-size: 14px; color: #e2e8f0; font-weight: 600;"><%= eventTime %></p>
                                                            </td>
                                                        </tr>
                                                        <tr>
                                                            <td>
                                                                <p style="margin: 0; font-size: 11px; color: #64748b; text-transform: uppercase; letter-spacing: 1px; font-weight: 600;">📍 Venue</p>
                                                                <p style="margin: 4px 0 0; font-size: 14px; color: #e2e8f0; font-weight: 600;"><%= eventVenue %></p>
                                                            </td>
                                                        </tr>
                                                    </table>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>

                            <!-- CTA Button -->
                            <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
                                <tr>
                                    <td align="center" style="padding-bottom: 32px;">
                                        <table role="presentation" cellpadding="0" cellspacing="0" style="border-radius: 12px; overflow: hidden; box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3), 0 0 20px rgba(99, 102, 241, 0.1);">
                                            <tr>
                                                <td style="background: linear-gradient(135deg, #6366f1, #7c3aed); padding: 14px 40px; text-align: center;">
                                                    <a href="<%= loginLink %>" style="color: #ffffff; font-size: 15px; font-weight: 700; text-decoration: none; display: inline-block; letter-spacing: 0.3px;">
                                                        🎫 View Invitation
                                                    </a>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>

                            <!-- Divider -->
                            <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
                                <tr>
                                    <td style="height: 1px; background: linear-gradient(90deg, transparent, #334155, transparent);"></td>
                                </tr>
                            </table>

                            <!-- Info Notice -->
                            <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
                                <tr>
                                    <td style="padding-top: 24px;">
                                        <p style="margin: 0; font-size: 12px; color: #475569; line-height: 1.6; text-align: center;">
                                            Log in to your Planora account to accept or decline this invitation.
                                        </p>
                                    </td>
                                </tr>
                            </table>

                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td style="background-color: #0f172a; padding: 20px 36px; border-top: 1px solid #1e293b;">
                            <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
                                <tr>
                                    <td align="center">
                                        <p style="margin: 0; font-size: 11px; color: #475569; line-height: 1.5;">
                                            © 2025 Planora. Secure Event Management Platform.
                                        </p>
                                        <p style="margin: 4px 0 0; font-size: 11px; color: #334155;">
                                            Built with ❤️ for event organizers worldwide.
                                        </p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                </table>

            </td>
        </tr>
    </table>
</body>
</html>
